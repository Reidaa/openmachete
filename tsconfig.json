{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["chrome"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": [
    "manifest.config.ts",
    "vite.config.ts",
    "src/**/*.ts"
  ]
}
